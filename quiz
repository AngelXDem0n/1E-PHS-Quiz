        <!-- ==================== LEADERBOARD SCREEN ==================== -->
        <div class="screen" id="screen-leaderboard">
            <div style="max-width:700px;margin:0 auto;padding:20px;">
                <h2 style="font-family:var(--font-display);letter-spacing:2px;text-align:center;">🏆 Leaderboard</h2>
                <div id="leaderboardContent" class="card" style="margin-top:16px;">
                    <p style="text-align:center;color:var(--text-secondary);">No data yet. Play a game to see results!</p>
                </div>
            </div>
        </div>

        <!-- ==================== GAME PLAY SCREEN ==================== -->
        <div class="screen" id="screen-game">
            <div class="game-container" id="gameArea">
                <!-- Dynamically filled -->
            </div>
        </div>

        <!-- ==================== END GAME SCREEN ==================== -->
        <div class="screen" id="screen-endgame">
            <div style="max-width:700px;margin:0 auto;padding:20px;text-align:center;" id="endGameContent">
                <!-- Dynamically filled -->
            </div>
        </div>

        <!-- Footer -->
        <div class="footer">
            <strong>RPRJ</strong> · Created by <strong>Jarus</strong> · © 2024 Quiz Arena
        </div>
    </div>

    <!-- ==================== MODALS ==================== -->
    <!-- Join Game Modal -->
    <div class="modal-overlay" id="joinModal" style="display:none;">
        <div class="modal">
            <h3>🎮 Join a Game</h3>
            <input class="input-field" type="text" id="joinName" placeholder="Your Name">
            <input class="input-field" type="text" id="joinCode" placeholder="Join Code">
            <div style="display:flex;gap:8px;margin-top:12px;">
                <button class="btn btn-accent" onclick="joinGame()">Join</button>
                <button class="btn btn-outline" onclick="closeModal('joinModal')">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Quiz Editor Modal -->
    <div class="modal-overlay" id="quizEditorModal" style="display:none;">
        <div class="modal" style="max-width:700px;">
            <h3>✏️ Quiz Editor</h3>
            <input class="input-field" type="text" id="quizTitle" placeholder="Quiz Title">
            <div id="questionsContainer" style="max-height:350px;overflow-y:auto;">
                <!-- Questions added dynamically -->
            </div>
            <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;">
                <button class="btn btn-outline btn-sm" onclick="addQuestionField()">+ Add Question</button>
                <button class="btn btn-primary" onclick="saveQuiz()">💾 Save Quiz</button>
                <button class="btn btn-outline btn-sm" onclick="closeModal('quizEditorModal')">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Settings Modal -->
    <div class="modal-overlay" id="settingsModal" style="display:none;">
        <div class="modal">
            <h3>⚙️ Settings</h3>
            <label>Theme</label>
            <select class="input-field" id="themeSelect" onchange="setTheme(this.value)">
                <option value="dark">🌌 Dark Mode</option>
                <option value="light">☀️ Light Mode</option>
            </select>
            <label>Default Timer (seconds)</label>
            <input class="input-field" type="number" id="defaultTimer" value="15" min="5" max="60">
            <label>Default Points</label>
            <input class="input-field" type="number" id="defaultPoints" value="100" min="10" max="1000">
            <button class="btn btn-primary" style="margin-top:10px;" onclick="saveSettings()">Save Settings</button>
            <button class="btn btn-outline btn-sm" style="margin-top:10px;" onclick="closeModal('settingsModal')">Close</button>
        </div>
    </div>

    <script>
        // ==================== GLOBAL STATE ====================
        const APP = {
            theme: 'dark',
            soundEnabled: true,
            quizzes: [],
            selectedQuiz: null,
            gameState: 'idle', // idle | waiting | playing | paused | ended
            players: [],
            currentQuestionIndex: 0,
            currentTimer: 15,
            timerInterval: null,
            timerRemaining: 0,
            joinCode: '',
            settings: {
                defaultTimer: 15,
                defaultPoints: 100,
            },
            leaderboardHistory: [],
        };

        // Load from localStorage
        function loadState() {
            try {
                const saved = JSON.parse(localStorage.getItem('rprj_quiz_arena') || '{}');
                APP.quizzes = saved.quizzes || [];
                APP.settings = { ...APP.settings, ...(saved.settings || {}) };
                APP.theme = saved.theme || 'dark';
                APP.soundEnabled = saved.soundEnabled !== false;
                APP.leaderboardHistory = saved.leaderboardHistory || [];
            } catch (e) { /* ignore */ }
        }

        function saveState() {
            localStorage.setItem('rprj_quiz_arena', JSON.stringify({
                quizzes: APP.quizzes,
                settings: APP.settings,
                theme: APP.theme,
                soundEnabled: APP.soundEnabled,
                leaderboardHistory: APP.leaderboardHistory,
            }));
        }

        loadState();
        document.documentElement.setAttribute('data-theme', APP.theme);
        if (!APP.soundEnabled) document.getElementById('soundBtn').textContent = '🔇';

        // ==================== LOADING SCREEN ====================
        let loadPercent = 0;
        const loadInterval = setInterval(() => {
            loadPercent += Math.floor(Math.random() * 8) + 3;
            if (loadPercent >= 100) {
                loadPercent = 100;
                clearInterval(loadInterval);
                setTimeout(() => {
                    document.getElementById('loadingScreen').classList.add('hidden');
                    document.getElementById('app').classList.add('visible');
                    initParticles();
                }, 400);
            }
            document.getElementById('loadPercent').textContent = loadPercent + '%';
            document.getElementById('loadBar').style.width = loadPercent + '%';
        }, 180);

        // ==================== PARTICLES ====================
        const pCanvas = document.getElementById('particlesCanvas');
        const pCtx = pCanvas.getContext('2d');
        let pArray = [];

        function resizePCanvas() {
            pCanvas.width = window.innerWidth;
            pCanvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resizePCanvas);
        resizePCanvas();

        class Particle {
            constructor() { this.reset(); }
            reset() {
                this.x = Math.random() * pCanvas.width;
                this.y = Math.random() * pCanvas.height;
                this.size = Math.random() * 2.5 + 1;
                this.sx = (Math.random() - 0.5) * 0.8;
                this.sy = (Math.random() - 0.5) * 0.8;
                this.alpha = Math.random() * 0.5 + 0.2;
            }
            update() {
                this.x += this.sx;
                this.y += this.sy;
                if (this.x < -20) this.x = pCanvas.width + 20;
                if (this.x > pCanvas.width + 20) this.x = -20;
                if (this.y < -20) this.y = pCanvas.height + 20;
                if (this.y > pCanvas.height + 20) this.y = -20;
            }
            draw() {
                pCtx.beginPath();
                pCtx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                pCtx.fillStyle = `rgba(168,133,250,${this.alpha})`;
                pCtx.fill();
            }
        }

        function initParticles() {
            const count = Math.min(Math.floor((pCanvas.width * pCanvas.height) / 7000), 120);
            pArray = Array.from({ length: count }, () => new Particle());
            if (!pAnimating) animateParticles();
        }
        let pAnimating = false;

        function animateParticles() {
            pAnimating = true;
            pCtx.clearRect(0, 0, pCanvas.width, pCanvas.height);
            pArray.forEach(p => { p.update();
                p.draw(); });
            // Draw connections
            for (let i = 0; i < pArray.length; i++) {
                for (let j = i + 1; j < pArray.length; j++) {
                    const dx = pArray[i].x - pArray[j].x;
                    const dy = pArray[i].y - pArray[j].y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    if (dist < 120) {
                        pCtx.beginPath();
                        pCtx.moveTo(pArray[i].x, pArray[i].y);
                        pCtx.lineTo(pArray[j].x, pArray[j].y);
                        pCtx.strokeStyle = `rgba(168,133,250,${(1-dist/120)*0.18})`;
                        pCtx.lineWidth = 0.5;
                        pCtx.stroke();
                    }
                }
            }
            requestAnimationFrame(animateParticles);
        }
        initParticles();

        // ==================== SCREEN NAVIGATION ====================
        function showScreen(name) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            const target = document.getElementById('screen-' + name);
            if (target) {
                target.classList.add('active');
                target.style.animation = 'none';
                target.offsetHeight;
                target.style.animation = 'screenIn 0.5s ease';
            }
            if (name === 'host') refreshHostDashboard();
            if (name === 'leaderboard') refreshLeaderboardScreen();
        }

        // ==================== MODALS ====================
        function showJoinModal() { document.getElementById('joinModal').style.display = 'flex'; }

        function showQuizEditor(quizIndex = null) {
            document.getElementById('quizEditorModal').style.display = 'flex';
            document.getElementById('quizTitle').value = '';
            document.getElementById('questionsContainer').innerHTML = '';
            if (quizIndex !== null && APP.quizzes[quizIndex]) {
                const q = APP.quizzes[quizIndex];
                document.getElementById('quizTitle').value = q.title;
                q.questions.forEach(qu => addQuestionField(qu));
            }
            if (document.getElementById('questionsContainer').children.length === 0) {
                addQuestionField();
                addQuestionField();
            }
        }

        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function showSettings() { document.getElementById('settingsModal').style.display = 'flex'; }

        // Close modals on overlay click
        document.addEventListener('click', (e) => {
            if (e.target.classList.contains('modal-overlay')) e.target.style.display = 'none';
        });

        // ==================== QUIZ EDITOR ====================
        function addQuestionField(prefill = null) {
            const container = document.getElementById('questionsContainer');
            const idx = container.children.length;
            const div = document.createElement('div');
            div.style.cssText =
                'border:1px solid var(--border);border-radius:10px;padding:14px;margin:8px 0;background:var(--surface);';
            div.innerHTML = `
            <strong>Q${idx+1}</strong>
            <input class="input-field" type="text" placeholder="Question" value="${prefill?.question||''}">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin:6px 0;">
              <input class="input-field" type="text" placeholder="Answer A" value="${prefill?.answers?.[0]||''}">
              <input class="input-field" type="text" placeholder="Answer B" value="${prefill?.answers?.[1]||''}">
              <input class="input-field" type="text" placeholder="Answer C" value="${prefill?.answers?.[2]||''}">
              <input class="input-field" type="text" placeholder="Answer D" value="${prefill?.answers?.[3]||''}">
            </div>
            <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
              <label>Correct:</label>
              <select class="input-field" style="width:auto;">
                <option value="0" ${prefill?.correct===0?'selected':''}>A</option>
                <option value="1" ${prefill?.correct===1?'selected':''}>B</option>
                <option value="2" ${prefill?.correct===2?'selected':''}>C</option>
                <option value="3" ${prefill?.correct===3?'selected':''}>D</option>
              </select>
              <label>Time(s):</label>
              <input class="input-field" type="number" value="${prefill?.time||APP.settings.defaultTimer}" style="width:70px;" min="5">
              <label>Points:</label>
              <input class="input-field" type="number" value="${prefill?.points||APP.settings.defaultPoints}" style="width:80px;" min="10">
              <button class="btn btn-danger btn-sm" onclick="this.parentElement.parentElement.remove()">✕</button>
            </div>
          `;
            container.appendChild(div);
        }

        function saveQuiz() {
            const title = document.getElementById('quizTitle').value.trim() || 'Untitled Quiz';
            const questionDivs = document.getElementById('questionsContainer').children;
            const questions = [];
            for (const div of questionDivs) {
                const inputs = div.querySelectorAll('input[type="text"]');
                const selects = div.querySelectorAll('select');
                const numInputs = div.querySelectorAll('input[type="number"]');
                if (inputs[0].value.trim()) {
                    questions.push({
                        question: inputs[0].value.trim(),
                        answers: [
                            inputs[1]?.value?.trim() || 'A',
                            inputs[2]?.value?.trim() || 'B',
                            inputs[3]?.value?.trim() || 'C',
                            inputs[4]?.value?.trim() || 'D'
                        ],
                        correct: parseInt(selects[0]?.value || 0),
                        time: parseInt(numInputs[0]?.value || APP.settings.defaultTimer),
                        points: parseInt(numInputs[1]?.value || APP.settings.defaultPoints),
                    });
                }
            }
            if (questions.length === 0) {
                alert('Please add at least one question.');
                return;
            }
            APP.quizzes.push({ title, questions });
            saveState();
            closeModal('quizEditorModal');
            refreshHostDashboard();
            showToast('✅ Quiz saved!');
        }

        // ==================== HOST DASHBOARD ====================
        function refreshHostDashboard() {
            const list = document.getElementById('quizList');
            if (APP.quizzes.length === 0) {
                list.innerHTML = '<p style="color:var(--text-secondary);">No quizzes yet. Create one!</p>';
            } else {
                list.innerHTML = APP.quizzes.map((q, i) => `
              <div class="quiz-list-item">
                <div>
                  <strong>${q.title}</strong>
                  <span class="badge badge-purple">${q.questions.length} Qs</span>
                </div>
                <div style="display:flex;gap:6px;">
                  <button class="btn btn-outline btn-sm" onclick="selectQuiz(${i})">Select</button>
                  <button class="btn btn-outline btn-sm" onclick="showQuizEditor(${i})">Edit</button>
                  <button class="btn btn-danger btn-sm" onclick="deleteQuiz(${i})">✕</button>
                </div>
              </div>
            `).join('');
            }
            document.getElementById('playerCount').textContent = APP.players.length;
            const plist = document.getElementById('playerList');
            if (APP.players.length === 0) {
                plist.innerHTML = '<p style="color:var(--text-secondary);">Waiting for players...</p>';
            } else {
                plist.innerHTML = APP.players.map((p, i) => `
              <div style="display:flex;justify-content:space-between;align-items:center;padding:8px;border-bottom:1px solid var(--border);">
                <span>${p.avatar||'👤'} ${p.name}</span>
                <span style="color:#22c55e;">${p.score||0} pts</span>
                <button class="btn btn-danger btn-sm" onclick="kickPlayer(${i})">Kick</button>
              </div>
            `).join('');
            }
            document.getElementById('joinCodeDisplay').textContent = APP.joinCode || '----';
        }

        function selectQuiz(index) {
            APP.selectedQuiz = APP.quizzes[index];
            APP.joinCode = generateJoinCode();
            document.getElementById('joinCodeDisplay').textContent = APP.joinCode;
            document.getElementById('hostStatus').textContent = `Selected: ${APP.selectedQuiz.title} | Join Code: ${APP.joinCode}`;
            document.getElementById('btnStartGame').disabled = false;
            showToast('📋 Quiz selected! Share join code: ' + APP.joinCode);
        }

        function deleteQuiz(index) {
            if (confirm('Delete this quiz?')) {
                APP.quizzes.splice(index, 1);
                saveState();
                refreshHostDashboard();
                showToast('🗑 Quiz deleted.');
            }
        }

        function generateJoinCode() {
            return Math.random().toString(36).substring(2, 8).toUpperCase();
        }

        function kickPlayer(index) {
            APP.players.splice(index, 1);
            refreshHostDashboard();
            showToast('👢 Player kicked.');
        }

        function hostResetLeaderboard() {
            APP.players.forEach(p => { p.score = 0;
                p.correct = 0;
                p.wrong = 0; });
            refreshHostDashboard();
            showToast('🔄 Leaderboard reset.');
        }

        function hostRandomizeQuestions() {
            if (APP.selectedQuiz) {
                APP.selectedQuiz.questions.sort(() => Math.random() - 0.5);
                showToast('🎲 Questions randomized!');
            }
        }

        // ==================== GAME CONTROLS (HOST) ====================
        function hostStartGame() {
            if (!APP.selectedQuiz) return alert('Select a quiz first.');
            if (APP.players.length === 0) {
                // Auto-add demo players for testing
                APP.players.push({ name: 'Player 1', avatar: '🦊', score: 0, correct: 0, wrong: 0, id: 'p1' });
                APP.players.push({ name: 'Player 2', avatar: '🐸', score: 0, correct: 0, wrong: 0, id: 'p2' });
            }
            APP.gameState = 'playing';
            APP.currentQuestionIndex = 0;
            document.getElementById('btnStartGame').disabled = true;
            document.getElementById('btnPauseGame').disabled = false;
            document.getElementById('btnEndGame').disabled = false;
            document.getElementById('btnResumeGame').disabled = true;
            showScreen('game');
            showCurrentQuestion();
            refreshHostDashboard();
        }

        function hostPauseGame() {
            APP.gameState = 'paused';
            clearInterval(APP.timerInterval);
            document.getElementById('btnPauseGame').disabled = true;
            document.getElementById('btnResumeGame').disabled = false;
            showToast('⏸ Game paused.');
        }

        function hostResumeGame() {
            APP.gameState = 'playing';
            document.getElementById('btnPauseGame').disabled = false;
            document.getElementById('btnResumeGame').disabled = true;
            startTimer();
            showToast('▶ Game resumed.');
        }

        function hostEndGame() {
            APP.gameState = 'ended';
            clearInterval(APP.timerInterval);
            document.getElementById('btnStartGame').disabled = false;
            document.getElementById('btnPauseGame').disabled = true;
            document.getElementById('btnResumeGame').disabled = true;
            document.getElementById('btnEndGame').disabled = true;
            showEndGameScreen();
        }

        // ==================== GAMEPLAY ====================
        function showCurrentQuestion() {
            if (!APP.selectedQuiz || APP.currentQuestionIndex >= APP.selectedQuiz.questions.length) {
                hostEndGame();
                return;
            }
            const q = APP.selectedQuiz.questions[APP.currentQuestionIndex];
            APP.currentTimer = q.time || APP.settings.defaultTimer;
            APP.timerRemaining = APP.currentTimer;
            const gameArea = document.getElementById('gameArea');
            gameArea.innerHTML = `
            <div style="text-align:center;margin-bottom:10px;">
              <span style="color:var(--text-secondary);">Question ${APP.currentQuestionIndex+1} / ${APP.selectedQuiz.questions.length}</span>
              <span style="margin-left:16px;color:#f59e0b;">⏱ ${APP.timerRemaining}s</span>
            </div>
            <div class="timer-bar"><div class="timer-fill" id="timerFill" style="width:100%;"></div></div>
            <div class="question-card" id="questionCard">
              <h3 style="font-size:1.3rem;margin-bottom:16px;">${q.question}</h3>
              ${q.answers.map((a,i) => `
                <button class="answer-btn" onclick="selectAnswer(${i})" id="ansBtn${i}">${String.fromCharCode(65+i)}) ${a}</button>
              `).join('')}
            </div>
            <button class="btn btn-outline btn-sm" onclick="showScreen('leaderboard')">📊 View Leaderboard</button>
          `;
            startTimer();
        }

        function startTimer() {
            clearInterval(APP.timerInterval);
            APP.timerInterval = setInterval(() => {
                APP.timerRemaining--;
                const pct = (APP.timerRemaining / APP.currentTimer) * 100;
                const fill = document.getElementById('timerFill');
                if (fill) {
                    fill.style.width = pct + '%';
                    fill.classList.remove('warning', 'danger');
                    if (pct < 30) fill.classList.add('danger');
                    else if (pct < 60) fill.classList.add('warning');
                }
                const timeSpan = document.querySelector('#gameArea span:nth-child(2)');
                if (timeSpan) timeSpan.textContent = '⏱ ' + APP.timerRemaining + 's';
                if (APP.timerRemaining <= 0) {
                    clearInterval(APP.timerInterval);
                    timeUp();
                }
            }, 1000);
        }

        function selectAnswer(index) {
            if (APP.gameState !== 'playing') return;
            clearInterval(APP.timerInterval);
            const q = APP.selectedQuiz.questions[APP.currentQuestionIndex];
            const correct = q.correct;
            const card = document.getElementById('questionCard');
            // Disable all buttons
            document.querySelectorAll('.answer-btn').forEach(b => b.disabled = true);
            // Highlight
            document.getElementById('ansBtn' + correct).classList.add('selected-correct');
            if (index === correct) {
                card.classList.add('correct-flash');
                spawnConfetti();
                playSound('correct');
                spawnScorePop('+'+q.points, '#22c55e');
                // Award points to all players (simulated)
                APP.players.forEach(p => { p.score += q.points;
                    p.correct = (p.correct || 0) + 1; });
            } else {
                document.getElementById('ansBtn' + index).classList.add('selected-wrong');
                card.classList.add('wrong-flash');
                playSound('wrong');
                APP.players.forEach(p => { p.wrong = (p.wrong || 0) + 1; });
            }
            // Next question after delay
            setTimeout(() => {
                APP.currentQuestionIndex++;
                if (APP.currentQuestionIndex >= APP.selectedQuiz.questions.length) {
                    hostEndGame();
                } else {
                    showTransitionThenNext();
                }
            }, 1800);
        }

        function timeUp() {
            const q = APP.selectedQuiz.questions[APP.currentQuestionIndex];
            document.querySelectorAll('.answer-btn').forEach(b => b.disabled = true);
            document.getElementById('ansBtn' + q.correct).classList.add('selected-correct');
            document.getElementById('questionCard').classList.add('wrong-flash');
            playSound('wrong');
            setTimeout(() => {
                APP.currentQuestionIndex++;
                if (APP.currentQuestionIndex >= APP.selectedQuiz.questions.length) {
                    hostEndGame();
                } else {
                    showTransitionThenNext();
                }
            }, 1500);
        }

        function showTransitionThenNext() {
            const gameArea = document.getElementById('gameArea');
            gameArea.innerHTML = `
            <div style="text-align:center;padding:60px 20px;">
              <h2 style="font-family:var(--font-display);font-size:2.5rem;animation:pulseGlow 0.8s infinite;">Next Question</h2>
              <div id="countdownNum" style="font-size:5rem;font-weight:900;color:#7c3aed;">3</div>
            </div>
          `;
            let cd = 3;
            const cdInterval = setInterval(() => {
                cd--;
                document.getElementById('countdownNum').textContent = cd > 0 ? cd : 'GO!';
                if (cd <= 0) {
                    clearInterval(cdInterval);
                    showCurrentQuestion();
                }
            }, 700);
        }

        // ==================== END GAME ====================
        function showEndGameScreen() {
            showScreen('endgame');
            const sorted = [...APP.players].sort((a, b) => (b.score || 0) - (a.score || 0));
            // Save to leaderboard history
            APP.leaderboardHistory.push({
                date: new Date().toISOString(),
                quiz: APP.selectedQuiz?.title || 'Quiz',
                players: sorted.map(p => ({ name: p.name, avatar: p.avatar, score: p.score, correct: p.correct,
                    wrong: p.wrong })),
            });
            saveState();
            const content = document.getElementById('endGameContent');
            const top3 = sorted.slice(0, 3);
            content.innerHTML = `
            <h1 style="font-family:var(--font-display);font-size:2.5rem;">🏆 Champion!</h1>
            <div class="podium">
              ${top3[1]?`<div class="podium-spot podium-2"><div style="font-size:3rem;">${top3[1].avatar||'🥈'}</div><strong>${top3[1].name}</strong><br>${top3[1].score||0} pts</div>`:''}
              ${top3[0]?`<div class="podium-spot podium-1"><div style="font-size:4rem;">${top3[0].avatar||'🥇'}</div><strong>${top3[0].name}</strong><br>${top3[0].score||0} pts</div>`:''}
              ${top3[2]?`<div class="podium-spot podium-3"><div style="font-size:2.5rem;">${top3[2].avatar||'🥉'}</div><strong>${top3[2].name}</strong><br>${top3[2].score||0} pts</div>`:''}
            </div>
            <h3>Final Rankings</h3>
            <table class="leaderboard-table" style="margin:0 auto;">
              <tr><th>Rank</th><th>Player</th><th>Score</th><th>Correct</th><th>Wrong</th></tr>
              ${sorted.map((p,i)=>`
                <tr>
                  <td class="${i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':''}">${i+1}</td>
                  <td>${p.avatar||'👤'} ${p.name}</td>
                  <td>${p.score||0}</td>
                  <td>${p.correct||0}</td>
                  <td>${p.wrong||0}</td>
                </tr>
              `).join('')}
            </table>
            <p style="margin-top:10px;">Total Questions: ${APP.selectedQuiz?.questions.length||0}</p>
            <button class="btn btn-primary" style="margin-top:16px;" onclick="showScreen('home');hostEndGame();">🏠 Back to Home</button>
            <button class="btn btn-outline btn-sm" style="margin-top:8px;" onclick="exportCSV()">📥 Export CSV</button>
          `;
            spawnConfetti(80);
            playSound('victory');
        }

        function exportCSV() {
            const sorted = [...APP.players].sort((a, b) => (b.score || 0) - (a.score || 0));
            let csv = 'Rank,Name,Score,Correct,Wrong\n';
            sorted.forEach((p, i) => {
                csv += `${i+1},${p.name},${p.score||0},${p.correct||0},${p.wrong||0}\n`;
            });
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'quiz_results.csv';
            a.click();
            URL.revokeObjectURL(url);
            showToast('📥 Results exported!');
        }

        // ==================== JOIN GAME ====================
        function joinGame() {
            const name = document.getElementById('joinName').value.trim();
            const code = document.getElementById('joinCode').value.trim();
            if (!name) return alert('Enter your name.');
            if (code !== APP.joinCode) return alert('Invalid join code.');
            const avatar = ['🦊', '🐸', '🐱', '🐶', '🦄', '🐲', '🦋', '🐼'][Math.floor(Math.random() * 8)];
            APP.players.push({ name, avatar, score: 0, correct: 0, wrong: 0, id: 'p' + Date.now() });
            closeModal('joinModal');
            refreshHostDashboard();
            showToast('✅ Joined! Wait for host to start.');
        }

        // ==================== LEADERBOARD SCREEN ====================
        function refreshLeaderboardScreen() {
            const content = document.getElementById('leaderboardContent');
            if (APP.leaderboardHistory.length === 0) {
                content.innerHTML =
                    '<p style="text-align:center;color:var(--text-secondary);">No data yet. Play a game to see results!</p>';
                return;
            }
            const latest = APP.leaderboardHistory[APP.leaderboardHistory.length - 1];
            const sorted = (latest.players || []).sort((a, b) => (b.score || 0) - (a.score || 0));
            content.innerHTML = `
            <h4 style="text-align:center;">📊 ${latest.quiz} — ${new Date(latest.date).toLocaleDateString()}</h4>
            <table class="leaderboard-table">
              <tr><th>Rank</th><th>Player</th><th>Score</th></tr>
              ${sorted.map((p,i)=>`
                <tr>
                  <td class="${i===0?'rank-1':i===1?'rank-2':i===2?'rank-3':''}">${i+1}</td>
                  <td>${p.avatar||'👤'} ${p.name}</td>
                  <td>${p.score||0}</td>
                </tr>
              `).join('')}
            </table>
          `;
        }

        // ==================== EFFECTS ====================
        function spawnConfetti(count = 40) {
            const colors = ['#7c3aed', '#06b6d4', '#f59e0b', '#22c55e', '#ef4444', '#a78bfa', '#ff6b6b', '#ffd93d'];
            for (let i = 0; i < count; i++) {
                const el = document.createElement('div');
                el.className = 'confetti-piece';
                el.style.cssText = `
              left:${Math.random()*100}vw;
              top:-${Math.random()*40+10}px;
              width:${Math.random()*10+6}px;
              height:${Math.random()*14+8}px;
              background:${colors[Math.floor(Math.random()*colors.length)]};
              border-radius:${Math.random()>0.5?'50%':'2px'};
              animation-duration:${Math.random()*2+2}s;
              animation-delay:${Math.random()*0.8}s;
            `;
                document.body.appendChild(el);
                setTimeout(() => el.remove(), 3000);
            }
        }

        function spawnScorePop(text, color) {
            const el = document.createElement('div');
            el.className = 'score-pop';
            el.textContent = text;
            el.style.cssText = `left:50%;top:40%;color:${color};transform:translateX(-50%);`;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 1300);
        }

        function showToast(msg) {
            const el = document.createElement('div');
            el.textContent = msg;
            el.style.cssText = `
            position:fixed;bottom:24px;left:50%;transform:translateX(-50%);z-index:500;
            background:rgba(20,20,40,0.95);color:#fff;padding:10px 22px;border-radius:25px;
            font-size:0.9rem;font-weight:600;border:1px solid rgba(168,133,250,0.5);
            box-shadow:0 0 20px rgba(124,58,237,0.4);animation:toastIn 0.4s ease, toastOut 0.4s ease 2s forwards;
          `;
            document.body.appendChild(el);
            setTimeout(() => el.remove(), 2500);
        }
        // Toast animations
        const toastStyle = document.createElement('style');
        toastStyle.textContent = `
          @keyframes toastIn{from{opacity:0;transform:translateX(-50%) translateY(20px);}to{opacity:1;transform:translateX(-50%) translateY(0);}}
          @keyframes toastOut{from{opacity:1;transform:translateX(-50%) translateY(0);}to{opacity:0;transform:translateX(-50%) translateY(-20px);}}
        `;
        document.head.appendChild(toastStyle);

        // ==================== SOUNDS (Web Audio API) ====================
        const audioCtx = new(window.AudioContext || window.webkitAudioContext)();

        function playSound(type) {
            if (!APP.soundEnabled) return;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            gain.gain.value = 0.15;
            switch (type) {
                case 'correct':
                    osc.frequency.setValueAtTime(523, audioCtx.currentTime);
                    osc.frequency.setValueAtTime(659, audioCtx.currentTime + 0.1);
                    osc.frequency.setValueAtTime(784, audioCtx.currentTime + 0.2);
                    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.4);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.4);
                    break;
                case 'wrong':
                    osc.type = 'sawtooth';
                    osc.frequency.setValueAtTime(200, audioCtx.currentTime);
                    osc.frequency.setValueAtTime(150, audioCtx.currentTime + 0.2);
                    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.35);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.35);
                    break;
                case 'victory':
                    osc.frequency.setValueAtTime(523, audioCtx.currentTime);
                    osc.frequency.setValueAtTime(659, audioCtx.currentTime + 0.15);
                    osc.frequency.setValueAtTime(784, audioCtx.currentTime + 0.3);
                    osc.frequency.setValueAtTime(1047, audioCtx.currentTime + 0.45);
                    gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.7);
                    osc.start();
                    osc.stop(audioCtx.currentTime + 0.7);
                    break;
            }
        }

        function toggleSound() {
            APP.soundEnabled = !APP.soundEnabled;
            document.getElementById('soundBtn').textContent = APP.soundEnabled ? '🔊' : '🔇';
            saveState();
        }

        // ==================== THEME ====================
        function toggleTheme() {
            APP.theme = APP.theme === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', APP.theme);
            document.getElementById('themeSelect').value = APP.theme;
            saveState();
        }

        function setTheme(t) {
            APP.theme = t;
            document.documentElement.setAttribute('data-theme', t);
            saveState();
        }
        document.getElementById('themeSelect').value = APP.theme;

        // ==================== FULLSCREEN ====================
        function toggleFullscreen() {
            if (!document.fullscreenElement) {
                document.documentElement.requestFullscreen().catch(() => {});
            } else {
                document.exitFullscreen();
            }
        }

        // ==================== SETTINGS ====================
        function saveSettings() {
            APP.settings.defaultTimer = parseInt(document.getElementById('defaultTimer').value) || 15;
            APP.settings.defaultPoints = parseInt(document.getElementById('defaultPoints').value) || 100;
            saveState();
            closeModal('settingsModal');
            showToast('⚙️ Settings saved!');
        }
        document.getElementById('defaultTimer').value = APP.settings.defaultTimer;
        document.getElementById('defaultPoints').value = APP.settings.defaultPoints;

        // ==================== KEYBOARD SHORTCUTS ====================
        document.addEventListener('keydown', (e) => {
            if (e.key === 'f' && e.ctrlKey) { e.preventDefault();
                toggleFullscreen(); }
            if (e.key === 'Escape') {
                document.querySelectorAll('.modal-overlay').forEach(m => m.style.display = 'none');
            }
        });

        // ==================== INIT ====================
        showScreen('home');
        refreshHostDashboard();
    </script>
</body>
</html>
