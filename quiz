                    </div>
                    <div class="card">
                        <h3>👥 Connected Players (<span id="playerCount">0</span>)</h3>
                        <div id="playerList" style="max-height:200px;overflow-y:auto;">
                            <p style="color:var(--text-secondary);">Waiting for players...</p>
                        </div>
                    </div>
                </div>
            </div>
