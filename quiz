<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RPRJ Quiz Arena</title>
    <style>
        :root {
            --bg: #0a0a14;
            --surface: #151525;
            --card: #1a1a30;
            --text: #e8e8f0;
            --text-secondary: #a0a0c0;
            --accent: #7c3aed;
            --accent-glow: #a78bfa;
            --accent2: #06b6d4;
            --accent3: #f59e0b;
            --success: #22c55e;
            --danger: #ef4444;
            --warning: #f59e0b;
            --border: rgba(255, 255, 255, 0.08);
            --glass: rgba(20, 20, 45, 0.7);
            --glass-border: rgba(255, 255, 255, 0.12);
            --shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
            --radius: 18px;
            --radius-sm: 10px;
            --transition: 0.35s cubic-bezier(0.25, 0.8, 0.25, 1.2);
            --font-main: 'Segoe UI', 'Poppins', 'Inter', system-ui, sans-serif;
            --font-display: 'Orbitron', 'Segoe UI', sans-serif;
        }
        [data-theme="light"] {
            --bg: #f0f0f8;
            --surface: #e8e8f4;
            --card: #ffffff;
            --text: #1a1a2e;
            --text-secondary: #555;
            --border: rgba(0, 0, 0, 0.1);
            --glass: rgba(255, 255, 255, 0.75);
            --glass-border: rgba(0, 0, 0, 0.15);
            --shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
        }
        body {
            font-family: var(--font-main);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            transition: background 0.5s, color 0.5s;
            position: relative;
        }
        /* Animated gradient background */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse at 20% 20%, rgba(124, 58, 237, 0.18) 0%, transparent 55%),
                radial-gradient(ellipse at 80% 60%, rgba(6, 182, 212, 0.12) 0%, transparent 55%),
                radial-gradient(ellipse at 50% 90%, rgba(245, 158, 11, 0.1) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
            animation: bgShift 18s ease-in-out infinite;
        }
        @keyframes bgShift {
            0%,
            100% {
                opacity: 0.8;
            }
            33% {
                opacity: 1;
            }
            66% {
                opacity: 0.6;
            }
        }
        #particlesCanvas {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
        }
        /* Loading Screen */
        #loadingScreen {
            position: fixed;
            inset: 0;
            z-index: 99999;
            background: #06060f;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.7s, visibility 0.7s;
            font-family: var(--font-display);
        }
        #loadingScreen.hidden {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .loading-logo {
            font-size: 3.5rem;
            font-weight: 900;
            letter-spacing: 6px;
            background: linear-gradient(135deg, #7c3aed, #06b6d4, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: pulseGlow 1.5s ease-in-out infinite;
            position: relative;
        }
        .loading-logo::after {
            content: '';
            position: absolute;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid transparent;
            border-top-color: #7c3aed;
            border-right-color: #06b6d4;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(0deg);
            animation: spinRing 2s linear infinite;
        }
        @keyframes spinRing {
            to {
                transform: translate(-50%, -50%) rotate(360deg);
            }
        }
        @keyframes pulseGlow {
            0%,
            100% {
                filter: drop-shadow(0 0 20px rgba(124, 58, 237, 0.6));
            }
            50% {
                filter: drop-shadow(0 0 45px rgba(6, 182, 212, 0.8));
            }
        }
        .loading-creator {
            margin-top: 16px;
            font-size: 0.95rem;
            color: #a0a0c0;
            letter-spacing: 2px;
            animation: fadeInUp 1s ease 0.3s both;
        }
        .loading-bar-wrap {
            width: 280px;
            height: 6px;
            background: #1a1a30;
            border-radius: 10px;
            margin-top: 28px;
            overflow: hidden;
        }
        .loading-bar-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #7c3aed, #06b6d4, #a78bfa);
            border-radius: 10px;
            transition: width 0.3s ease;
            animation: loadGrow 2.2s ease-in-out forwards;
        }
        @keyframes loadGrow {
            0% {
                width: 0%;
            }
            40% {
                width: 45%;
            }
            70% {
                width: 78%;
            }
            100% {
                width: 100%;
            }
        }
        .loading-percent {
            margin-top: 10px;
            font-size: 1.2rem;
            color: #a78bfa;
            letter-spacing: 2px;
        }
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Main App */
        #app {
            position: relative;
            z-index: 1;
            opacity: 0;
            transform: translateY(20px);
            transition: opacity 0.6s 0.3s, transform 0.6s 0.3s;
        }
        #app.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .screen {
            display: none;
            animation: screenIn 0.5s ease;
        }
        .screen.active {
            display: block;
        }
        @keyframes screenIn {
            from {
                opacity: 0;
                transform: translateY(25px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Navigation */
        .navbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 24px;
            background: var(--glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
            position: sticky;
            top: 0;
            z-index: 100;
            flex-wrap: wrap;
            gap: 10px;
        }
        .nav-brand {
            font-family: var(--font-display);
            font-size: 1.3rem;
            font-weight: 800;
            letter-spacing: 2px;
            background: linear-gradient(135deg, #7c3aed, #06b6d4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            cursor: pointer;
        }
        .nav-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            flex-wrap: wrap;
        }
        .btn {
            padding: 10px 20px;
            border-radius: 25px;
            border: none;
            cursor: pointer;
            font-weight: 600;
            letter-spacing: 0.5px;
            transition: var(--transition);
            font-family: var(--font-main);
            font-size: 0.9rem;
            position: relative;
            overflow: hidden;
        }
        .btn-primary {
            background: #7c3aed;
            color: #fff;
            box-shadow: 0 0 20px rgba(124, 58, 237, 0.4);
        }
        .btn-primary:hover {
            box-shadow: 0 0 35px rgba(124, 58, 237, 0.7);
            transform: translateY(-2px);
        }
        .btn-accent {
            background: #06b6d4;
            color: #000;
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.4);
        }
        .btn-accent:hover {
            box-shadow: 0 0 35px rgba(6, 182, 212, 0.7);
            transform: translateY(-2px);
        }
        .btn-outline {
            background: transparent;
            border: 2px solid var(--glass-border);
            color: var(--text);
        }
        .btn-outline:hover {
            border-color: #7c3aed;
            box-shadow: 0 0 25px rgba(124, 58, 237, 0.3);
        }
        .btn-danger {
            background: #ef4444;
            color: #fff;
            box-shadow: 0 0 18px rgba(239, 68, 68, 0.4);
        }
        .btn-sm {
            padding: 6px 14px;
            font-size: 0.8rem;
            border-radius: 20px;
        }
        .btn-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            padding: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            background: var(--glass);
            border: 2px solid var(--glass-border);
            color: var(--text);
            cursor: pointer;
            transition: var(--transition);
        }
        .btn-icon:hover {
            border-color: #7c3aed;
            box-shadow: 0 0 20px rgba(124, 58, 237, 0.35);
        }

        /* Cards */
        .card {
            background: var(--glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
            transition: var(--transition);
        }
        .card:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 50px rgba(0, 0, 0, 0.55);
        }

        /* Home Screen */
        .home-hero {
            text-align: center;
            padding: 60px 20px 30px;
        }
        .home-title {
            font-family: var(--font-display);
            font-size: clamp(2.2rem, 5vw, 4rem);
            font-weight: 900;
            letter-spacing: 3px;
            background: linear-gradient(135deg, #7c3aed, #06b6d4, #a78bfa, #f59e0b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: titleShimmer 3s ease-in-out infinite;
            background-size: 300% 300%;
        }
        @keyframes titleShimmer {
            0%,
            100% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
        }
        .home-subtitle {
            font-size: 1.2rem;
            color: var(--text-secondary);
            letter-spacing: 1px;
            margin: 8px 0 30px;
        }
        .home-buttons {
            display: flex;
            gap: 16px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .home-buttons .btn {
            font-size: 1.1rem;
            padding: 14px 30px;
            border-radius: 30px;
            letter-spacing: 1px;
        }

        /* Host Dashboard */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 18px;
            padding: 20px;
        }
        .quiz-list-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 14px 18px;
            background: var(--surface);
            border-radius: var(--radius-sm);
            margin: 8px 0;
            transition: var(--transition);
            border: 1px solid var(--border);
        }
        .quiz-list-item:hover {
            border-color: #7c3aed;
            box-shadow: 0 0 20px rgba(124, 58, 237, 0.2);
        }
        .badge {
            padding: 4px 12px;
            border-radius: 15px;
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .badge-purple {
            background: rgba(124, 58, 237, 0.2);
            color: #a78bfa;
        }
        .badge-cyan {
            background: rgba(6, 182, 212, 0.2);
            color: #06b6d4;
        }

        /* Game Area */
        .game-container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
            text-align: center;
        }
        .question-card {
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 2px solid var(--glass-border);
            border-radius: var(--radius);
            padding: 30px 24px;
            margin: 20px 0;
            box-shadow: var(--shadow);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .question-card.correct-flash {
            border-color: #22c55e !important;
            box-shadow: 0 0 50px rgba(34, 197, 94, 0.5) !important;
            animation: correctPulse 0.6s ease;
        }
        .question-card.wrong-flash {
            border-color: #ef4444 !important;
            box-shadow: 0 0 50px rgba(239, 68, 68, 0.5) !important;
            animation: shake 0.5s ease;
        }
        @keyframes correctPulse {
            0%,
            100% {
                transform: scale(1);
            }
            50% {
                transform: scale(1.03);
            }
        }
        @keyframes shake {
            0%,
            100% {
                transform: translateX(0);
            }
            20% {
                transform: translateX(-8px);
            }
            40% {
                transform: translateX(8px);
            }
            60% {
                transform: translateX(-6px);
            }
            80% {
                transform: translateX(4px);
            }
        }
        .answer-btn {
            display: block;
            width: 100%;
            padding: 14px 20px;
            margin: 8px 0;
            border-radius: var(--radius-sm);
            border: 2px solid var(--border);
            background: var(--surface);
            color: var(--text);
            cursor: pointer;
            font-size: 1rem;
            transition: var(--transition);
            text-align: left;
            font-family: var(--font-main);
        }
        .answer-btn:hover {
            border-color: #7c3aed;
            background: rgba(124, 58, 237, 0.1);
            transform: translateX(4px);
        }
        .answer-btn.selected-correct {
            border-color: #22c55e !important;
            background: rgba(34, 197, 94, 0.2) !important;
            color: #22c55e !important;
            animation: correctPulse 0.5s ease;
        }
        .answer-btn.selected-wrong {
            border-color: #ef4444 !important;
            background: rgba(239, 68, 68, 0.2) !important;
            color: #ef4444 !important;
            animation: shake 0.5s ease;
        }
        .timer-bar {
            height: 8px;
            background: #2a2a40;
            border-radius: 10px;
            margin: 16px 0;
            overflow: hidden;
        }
        .timer-fill {
            height: 100%;
            border-radius: 10px;
            transition: width 0.1s linear, background 0.5s;
            background: #22c55e;
        }
        .timer-fill.warning {
            background: #f59e0b;
        }
        .timer-fill.danger {
            background: #ef4444;
            animation: pulseDanger 0.5s infinite;
        }
        @keyframes pulseDanger {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.5;
            }
        }
        .score-pop {
            position: fixed;
            pointer-events: none;
            font-weight: 900;
            font-size: 2rem;
            z-index: 200;
            animation: scoreFly 1.2s ease-out forwards;
        }
        @keyframes scoreFly {
            0% {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
            100% {
                opacity: 0;
                transform: translateY(-120px) scale(1.8);
            }
        }

        /* Leaderboard */
        .leaderboard-table {
            width: 100%;
            border-collapse: collapse;
        }
        .leaderboard-table th,
        .leaderboard-table td {
            padding: 12px 16px;
            text-align: left;
            border-bottom: 1px solid var(--border);
        }
        .leaderboard-table th {
            font-family: var(--font-display);
            font-size: 0.8rem;
            letter-spacing: 1px;
            color: var(--text-secondary);
            text-transform: uppercase;
        }
        .rank-1 {
            color: #f59e0b;
            font-weight: 900;
            font-size: 1.4rem;
        }
        .rank-2 {
            color: #c0c0c0;
            font-weight: 700;
        }
        .rank-3 {
            color: #cd7f32;
            font-weight: 600;
        }
        .rank-change-up {
            color: #22c55e;
            animation: bounceUp 0.5s ease;
        }
        .rank-change-down {
            color: #ef4444;
        }
        @keyframes bounceUp {
            0%,
            100% {
                transform: translateY(0);
            }
            50% {
                transform: translateY(-6px);
            }
        }

        /* Modal */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.7);
            z-index: 300;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: fadeIn 0.3s ease;
        }
        .modal {
            background: var(--card);
            border-radius: var(--radius);
            padding: 28px;
            max-width: 600px;
            width: 90%;
            max-height: 85vh;
            overflow-y: auto;
            box-shadow: var(--shadow);
            border: 1px solid var(--glass-border);
            animation: zoomIn 0.3s ease;
        }
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }
        @keyframes zoomIn {
            from {
                opacity: 0;
                transform: scale(0.9);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
        .modal h3 {
            font-family: var(--font-display);
            letter-spacing: 1px;
            margin-bottom: 16px;
        }
        .input-field {
            width: 100%;
            padding: 12px 16px;
            border-radius: 25px;
            border: 2px solid var(--border);
            background: var(--surface);
            color: var(--text);
            font-family: var(--font-main);
            font-size: 0.95rem;
            margin: 8px 0;
            transition: var(--transition);
        }
        .input-field:focus {
            outline: none;
            border-color: #7c3aed;
            box-shadow: 0 0 20px rgba(124, 58, 237, 0.25);
        }

        /* Confetti */
        .confetti-piece {
            position: fixed;
            z-index: 400;
            pointer-events: none;
            animation: confettiFall 2.5s ease-out forwards;
        }
        @keyframes confettiFall {
            0% {
                opacity: 1;
                transform: translateY(-100vh) rotate(0deg) scale(1);
            }
            100% {
                opacity: 0;
                transform: translateY(105vh) rotate(720deg) scale(0.3);
            }
        }

        /* Podium */
        .podium {
            display: flex;
            align-items: flex-end;
            justify-content: center;
            gap: 12px;
            margin: 30px 0;
            flex-wrap: wrap;
        }
        .podium-spot {
            text-align: center;
            padding: 20px;
            border-radius: var(--radius-sm);
            min-width: 100px;
            animation: podiumRise 0.7s ease-out;
        }
        .podium-1 {
            background: linear-gradient(180deg, rgba(245, 158, 11, 0.3), rgba(245, 158, 11, 0.05));
            border: 2px solid #f59e0b;
            min-height: 200px;
        }
        .podium-2 {
            background: linear-gradient(180deg, rgba(192, 192, 192, 0.2), rgba(192, 192, 192, 0.03));
            border: 2px solid #c0c0c0;
            min-height: 160px;
        }
        .podium-3 {
            background: linear-gradient(180deg, rgba(205, 127, 50, 0.2), rgba(205, 127, 50, 0.03));
            border: 2px solid #cd7f32;
            min-height: 130px;
        }
        @keyframes podiumRise {
            from {
                opacity: 0;
                transform: translateY(40px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Footer */
        .footer {
            text-align: center;
            padding: 20px;
            border-top: 1px solid var(--border);
            margin-top: 40px;
            color: var(--text-secondary);
            font-size: 0.85rem;
            letter-spacing: 1px;
        }
        .footer strong {
            color: #a78bfa;
            font-family: var(--font-display);
        }

        /* Responsive */
        @media (max-width: 600px) {
            .navbar {
                padding: 8px 12px;
            }
            .nav-brand {
                font-size: 1rem;
            }
            .home-title {
                font-size: 2rem;
            }
            .btn {
                padding: 8px 14px;
                font-size: 0.8rem;
            }
            .dashboard-grid {
                grid-template-columns: 1fr;
                padding: 10px;
            }
            .game-container {
                padding: 10px;
            }
            .question-card {
                padding: 16px 12px;
            }
        }
    </style>
</head>
<body>

    <!-- Particles Canvas -->
    <canvas id="particlesCanvas"></canvas>

    <!-- ==================== LOADING SCREEN ==================== -->
    <div id="loadingScreen">
        <div class="loading-logo">RPRJ</div>
        <div class="loading-creator">Created by Jarus</div>
        <div class="loading-bar-wrap">
            <div class="loading-bar-fill" id="loadBar"></div>
        </div>
        <div class="loading-percent" id="loadPercent">0%</div>
    </div>

    <!-- ==================== MAIN APP ==================== -->
    <div id="app">
        <!-- Navbar -->
        <nav class="navbar">
            <span class="nav-brand" onclick="showScreen('home')">⚡ RPRJ Quiz Arena</span>
            <div class="nav-actions">
                <button class="btn-icon" onclick="toggleTheme()" title="Toggle Theme">🌓</button>
                <button class="btn-icon" onclick="toggleSound()" title="Toggle Sound" id="soundBtn">🔊</button>
                <button class="btn-icon" onclick="toggleFullscreen()" title="Fullscreen">⛶</button>
                <button class="btn btn-outline btn-sm" onclick="showScreen('home')">🏠 Home</button>
            </div>
        </nav>

        <!-- ==================== HOME SCREEN ==================== -->
        <div class="screen active" id="screen-home">
            <div class="home-hero">
                <h1 class="home-title">RPRJ Quiz Arena</h1>
                <p class="home-subtitle">The Ultimate Classroom Challenge</p>
                <div class="home-buttons">
                    <button class="btn btn-accent" onclick="showJoinModal()">🎮 Join Game</button>
                    <button class="btn btn-primary" onclick="showScreen('host')">🎯 Host Game</button>
                    <button class="btn btn-outline" onclick="showScreen('leaderboard')">🏆 Leaderboard</button>
                    <button class="btn btn-outline" onclick="showSettings()">⚙️ Settings</button>
                </div>
            </div>
        </div>

        <!-- ==================== HOST DASHBOARD ==================== -->
        <div class="screen" id="screen-host">
            <div style="max-width:1000px;margin:0 auto;padding:20px;">
                <h2 style="font-family:var(--font-display);letter-spacing:2px;margin-bottom:16px;">🎯 Host Dashboard</h2>
                <div class="dashboard-grid">
                    <div class="card">
                        <h3>📋 Your Quizzes</h3>
                        <div id="quizList" style="max-height:300px;overflow-y:auto;">
                            <p style="color:var(--text-secondary);">No quizzes yet. Create one!</p>
                        </div>
                        <button class="btn btn-primary" style="margin-top:12px;" onclick="showQuizEditor()">+ Create New Quiz</button>
                    </div>
                    <div class="card">
                        <h3>🎮 Game Controls</h3>
                        <p id="hostStatus" style="color:var(--text-secondary);">No active game. Select a quiz and start.</p>
                        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:10px;">
                            <button class="btn btn-accent btn-sm" id="btnStartGame" onclick="hostStartGame()">▶ Start</button>
                            <button class="btn btn-outline btn-sm" id="btnPauseGame" onclick="hostPauseGame()" disabled>⏸ Pause</button>
